def check_waf_block(page):
    """WAF 防火墙与 500 报错雷达检测"""
    try:
        html_text = page.html
       
        waf_keywords = [ "IP"]
        for kw in waf_keywords:
            if kw in html_text:
                return kw
        return None
    except:
        return None


def load_json(file, default):
    if os.path.exists(file):
        try:
            with open(file, 'r', encoding='utf-8') as f:
                return json.load(f)
        except:
            pass
    return default

def kill_browser():
    print("💀 正在清理旧浏览器进程...")
    os.system('taskkill /F /IM msedge.exe >nul 2>&1')
    time.sleep(2)

def start_browser():
    print("🔥 正在启动浏览器...")
    if not os.path.exists(BAT_PATH):
        print("❌ 错误：找不到启动脚本！")
        return None
    subprocess.Popen(f'"{BAT_PATH}"', shell=True)
    print("   ⏳ 等待浏览器预热 (8秒)...")
    time.sleep(8)
    try:
        return ChromiumPage(addr_or_opts=9222)
    except:
        print("❌ 连接浏览器失败")
        return None

def clean_filename(text):
    """清洗文件名，去除非法字符"""
    return re.sub(r'[\\/:*?"<>|]', '_', text)

