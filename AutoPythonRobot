def debug_login_process(page, user, pwd):
    t_print = lambda msg: print(f"[{time.strftime('%H:%M:%S')}] {msg}")
    t_print(f"🚀 [V80] 开始执行登录调试 (当前账号: {user})...")

    url = "https://wenshu.court.gov.cn/website/wenshu/181107ANFZ0BXSK4/index.html"
