def calculate_resume_coordinates(file_count):
    if file_count < 5:
        return 1, file_count
    remaining = file_count - 5
    page_add = remaining // 15
    current_idx = remaining % 15
    target_page = 1 + page_add + 1
    if current_idx == 0 and remaining > 0:
        target_page = 1 + page_add
        return target_page, 15
    return target_page, current_idx


