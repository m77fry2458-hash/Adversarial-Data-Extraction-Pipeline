    if page.ele('#cprqStart', timeout=3):
        t_print("✅ 检测到【日期框】，说明当前已是登录状态！")
        return True

    t_print("🔒 当前未登录，准备寻找登录入口...")
    iframe = page.get_frame('#contentIframe')
    if not iframe:
        t_print("   ⚠️ 页面上没看到登录框 Iframe，尝试点击【登录】按钮触发...")
        login_btn = page.ele('text:登录') or page.ele('#loginLi')
        if login_btn:
            login_btn.click(by_js=True)
            t_print("   👆 点击了登录按钮，等待弹窗...")
            time.sleep(3)
            iframe = page.get_frame('#contentIframe')

    if not iframe:
        t_print("❌ 致命错误：无法定位到 id='contentIframe' 的登录框！")
        return False
    else:
        t_print("✅ 成功锁定登录 Iframe")

    t_print("   ✍️ 正在填写账号密码...")
    try:
        u_input = iframe.ele('css:input[placeholder*="手机"]') or iframe.ele('css:input[name="username"]')
        p_input = iframe.ele('css:input[placeholder*="密码"]') or iframe.ele('css:input[name="password"]')

        if u_input and p_input:
            u_input.clear()
            u_input.input(user)
            time.sleep(3)

            p_input.clear()
            p_input.input(pwd)
            time.sleep(3)

            t_print("      ✅ 账号密码已填入")
        else:
            t_print("      ❌ 错误：找不到账号或密码输入框！")
            return False
    except Exception as e:
        t_print(f"      ❌ 填表异常: {e}")
        return False

    # 👇 三轮被动读取机制
    for attempt in range(1, 4):
        t_print(f"\n   🧩 [第 {attempt}/3 轮] 正在提取网页验证码...")
        try:
            img_ele = iframe.ele('.captcha-img')
            if not img_ele:
                t_print("      ❌ 错误：找不到验证码图片元素 (.captcha-img)")
                return False

            src = img_ele.attr('src')
            if not src or "base64" not in src:
                t_print(f"      ❌ 错误：图片 src 不是 Base64 格式...")
                return False

            base64_data = src.split("base64,")[1]
            img_bytes = base64.b64decode(base64_data)
            img_hash = hashlib.md5(img_bytes).hexdigest()
            t_print(f"      📸 图片哈希值: {img_hash}")

            db = load_json(CAPTCHA_DB_FILE, {})
            if img_hash in db:
                code = db[img_hash]
                t_print(f"      🧠 指纹库匹配成功: [{code}]")
                code_input = iframe.ele('css:input[placeholder*="验证码"]')
                if code_input:
                    code_input.clear()
                    code_input.input(code)
                    t_print(f"      ✅ 验证码 [{code}] 已填入输入框")
                    time.sleep(3)
                else:
                    return False
            else:
                t_print(f"      ❌ 失败：此验证码指纹 ({img_hash}) 不在库中！")
                if attempt < 3:
                    t_print("      ⏳ 怀疑网页正在暗中刷新图片，静待 4 秒后重新抓取...")
                    time.sleep(4)
                    continue
                else:
                    return False

            t_print(f"   👆 [第 {attempt} 轮] 准备点击登录按钮...")
            for i in range(1, 3):
                t_print(f"      [{i}/2] 点击登录...")
                login_btn = iframe.ele('text:登录') or iframe.ele('.login-button-container')

                time.sleep(3)

                if login_btn:
                    login_btn.click(by_js=True)

                if page.ele('#cprqStart', timeout=3):
                    t_print("   🎉🎉🎉 登录成功！")
                    return True

                t_print("      ⚠️ 未跳转，等待重试...")
                time.sleep(4)

                if page.ele('#cprqStart', timeout=1):
                    t_print("   🎉 延迟跳转成功！")
                    return True

            if attempt < 3:
                t_print("   🚨 两次点击无响应！怀疑网页已悄悄更换验证码，准备重新提取比对...")
                time.sleep(4)

        except Exception as e:
            t_print(f"      ❌ 本轮验证码处理异常: {e}")
            if attempt == 3:
                return False

    t_print("❌ 三轮静默读取与尝试均失败，放弃挣扎，准备重启浏览器...")
    return False


